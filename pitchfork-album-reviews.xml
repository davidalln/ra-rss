  <item>
    <title>The Bug Club – Every Single Muscle</title>
    <link>https://pitchfork.com/reviews/albums/the-bug-club-every-single-muscle/</link>
    <guid isPermaLink="true">https://pitchfork.com/reviews/albums/the-bug-club-every-single-muscle/</guid>
